    {
        "id": "042cae2839d91a7a",
        "type": "function",
        "z": "cbd90930c9da13e1",
        "name": "function 1",
        "func": "var id = msg.payload.device_id;\nvar tempMsg = { payload: msg.payload.temperature };\nvar humMsg = { payload: msg.payload.humidity };\n\nif (id === \"ESP32_PhongKhachin\") {\n    return [tempMsg, humMsg, null, null];\n} else if (id === \"ESP32_PhongKhachout\") {\n    return [null, null, tempMsg, humMsg];\n}\nreturn [null, null, null, null];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
