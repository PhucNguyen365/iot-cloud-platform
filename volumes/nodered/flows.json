        "name": "function 3",
        "func": "let tempIn = [], humIn = [];\nlet tempOut = [], humOut = [];\n\nif (!msg.payload || !Array.isArray(msg.payload)) {\n    return [null, null, null, null];\n}\n\nmsg.payload.forEach(row => {\n    let t = Number(row.time_bucket);\n    let temp = Number(row.temp);\n    let hum = Number(row.hum);\n\n    // GÁN CHUẨN QUỐC TẾ x VÀ y\n    if (row.device_id === 'ESP32_PhongKhachin') {\n        tempIn.push({ x: t, y: temp });\n        humIn.push({ x: t, y: hum });\n    } else if (row.device_id === 'ESP32_PhongKhachout') {\n        tempOut.push({ x: t, y: temp });\n        humOut.push({ x: t, y: hum });\n    }\n});\n\nlet msgTempIn = { topic: \"Nhiệt độ Trong nhà\", payload: tempIn };\nlet msgHumIn = { topic: \"Độ ẩm Trong nhà\", payload: humIn };\nlet msgTempOut = { topic: \"Nhiệt độ Ngoài trời\", payload: tempOut };\nlet msgHumOut = { topic: \"Độ ẩm Ngoài trời\", payload: humOut };\n\nreturn [msgTempIn, msgHumIn, msgTempOut, msgHumOut];",
