    {
        "id": "67f46d91dd8f59ba",
        "type": "function",
        "z": "6fce02be3b0436a0",
        "name": "function 2",
        "func": "msg.topic = `\n    SELECT \n        device_id,\n        UNIX_TIMESTAMP(DATE_FORMAT(created_at, '%Y-%m-%d %H:00:00')) * 1000 AS time_bucket, \n        ROUND(AVG(temperature), 1) as temp, \n        ROUND(AVG(humidity), 1) as hum \n    FROM sensor_data \n    WHERE device_id IN ('ESP32_PhongKhachin', 'ESP32_PhongKhachout')\n      AND created_at >= NOW() - INTERVAL 7 DAY \n    GROUP BY device_id, time_bucket \n    ORDER BY time_bucket ASC;\n`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 340,
        "wires": [
            [
                "dde4dee6280ca8a0"
            ]
        ]
    },
